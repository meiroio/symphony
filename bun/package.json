{
  "name": "symphony-bun",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun run src/cli.ts",
    "prod": "NODE_ENV=production bun run src/cli.ts",
    "linear:local": "NODE_ENV=production bun run src/cli.ts ./WORKFLOW.linear.local.md",
    "start": "bun run prod",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:pr-body": "bun run scripts/check-pr-body.ts"
  },
  "dependencies": {
    "elysia": "^1.4.27",
    "js-yaml": "^4.1.0",
    "liquidjs": "^10.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
