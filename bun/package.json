{
  "name": "symphony-bun",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "linear:local": "bun run src/cli.ts ./workflows/WORKFLOW.linear.local.md",
    "linear:team-review:local": "bun run src/cli.ts ./workflows/WORKFLOW.linear.team-review.local.md",
    "workflows": "bun run src/run-workflows.ts ./workflows",
    "start": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:pr-body": "bun run scripts/check-pr-body.ts"
  },
  "dependencies": {
    "elysia": "^1.4.27",
    "js-yaml": "^4.1.0",
    "liquidjs": "^10.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
